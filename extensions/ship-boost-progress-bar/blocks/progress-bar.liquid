{% comment %}
  ShipBoost — Free Shipping Progress Bar (section app block).

  Merchants add this block to a section (e.g. the product page) via the Theme
  Editor. Rendering lives in the shared snippet so the section block and the
  site-wide app embed stay identical. `block.shopify_attributes` is forwarded so
  the Theme Editor can select the block.
{% endcomment %}
{% render 'ship-boost-bar', sb_shopify_attributes: block.shopify_attributes %}

{% schema %}
{
  "name": "ShipBoost Progress Bar",
  "target": "section",
  "stylesheet": "ship-boost-progress-bar.css",
  "javascript": "ship-boost-progress-bar.js",
  "settings": []
}
{% endschema %}
