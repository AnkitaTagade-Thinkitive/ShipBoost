# ShipBoost environment variables
# ---------------------------------
# Copy this file to `.env` for local development (`cp .env.example .env`).
# In production, set these as real environment variables in your host — do NOT
# commit a real .env. Nothing in the codebase needs editing to deploy; provide
# the production URL and these variables and the app runs as-is.

# --- Database (required) ---------------------------------------------------
# Prisma datasource is PostgreSQL (e.g. Neon). Two URLs are needed:
#   DATABASE_URL — pooled connection, used by the app at runtime.
#   DIRECT_URL   — direct (non-pooled) connection, used by `prisma migrate`.
# On Neon the direct URL is the same connection string with the "-pooler"
# segment removed from the host. Both must be set in every environment that
# runs migrations (local, CI, and production).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- Shopify app credentials (required) ------------------------------------
# From your app in the Shopify Partner Dashboard. During local development
# `shopify app dev` injects these automatically; set them explicitly in
# production hosting.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# Comma-separated access scopes. Must match shopify.app.toml (read_themes).
SCOPES="read_themes"

# The app's public HTTPS URL (your production host, e.g. https://your-app.example).
# `shopify app dev` sets this to the tunnel URL automatically in development.
SHOPIFY_APP_URL=""

# --- Public link overrides (optional) --------------------------------------
# The in-app footer / Help links point to the in-app Help page by default. Once
# the public ShipBoost website (in ./website) is hosted, set these to the live
# pages and every link updates automatically — no code changes. Build-time vars,
# so rebuild after changing them.
# VITE_DOCS_URL="https://your-shipboost-site.example/docs.html"
# VITE_SUPPORT_URL="https://your-shipboost-site.example/support.html"
# VITE_PRIVACY_URL="https://your-shipboost-site.example/privacy.html"

# --- Optional -------------------------------------------------------------
# Custom storefront domain, only if your dev store uses one.
# SHOP_CUSTOM_DOMAIN=""

# Port the production server listens on (defaults to 3000).
# PORT="3000"
